# Database Connection
# Neon DB URL (standard PostgreSQL format)
# The backend automatically converts postgresql:// to postgresql+asyncpg://
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require

# Async connection pool (Neon / serverless Postgres — tune for concurrent admin polls)
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
# DB_POOL_RECYCLE_SECONDS=280
# DB_POOL_TIMEOUT_SECONDS=30

# Local DB Fallback (if not using DATABASE_URL)
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres

# Frontend URL for invite links, emails (localhost in dev; set on deploy)
FRONTEND_BASE_URL=http://localhost:5173
WEBSITE_URL=http://localhost:5173

# Security
SECRET_KEY=generate_a_random_hex_string_here
# Platform admin browser login (HttpOnly cookie — do not put in frontend)
ZENK_ADMIN_EMAIL=admin@zenk
ZENK_ADMIN_PASSWORD=choose_a_strong_admin_password_here
# Optional server-to-server admin key (CI/scripts only — never VITE_* in frontend)
# ZENK_ADMIN_API_KEY=generate_a_long_random_admin_key_here
# Local dev only (never true in production): skip admin key when ZENK_ADMIN_API_KEY is unset
# ZENK_ADMIN_ALLOW_OPEN_DEV=true
# Dev only — never true in production (blocks silent demo-circle enrollment)
ZENK_ALLOW_DEMO_CIRCLE=false
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
# HttpOnly cookies: false for local http://localhost; auto-true on Railway.
# When true, cookies use SameSite=None so Vercel FE can send session cookies to Railway API.
AUTH_COOKIE_SECURE=false
# Optional extra CORS origins (comma-separated), e.g. preview deploy URLs
# CORS_EXTRA_ORIGINS=https://your-branch.vercel.app
# OpenAPI / Swagger UI — auto-off on Railway and when AUTH_COOKIE_SECURE=true or HTTPS FRONTEND_BASE_URL
# ENABLE_API_DOCS=true

# AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Impact Briefing uses Google News RSS (no API key). Optional legacy key unused:
# GUARDIAN_API_KEY=

# ICICI corporate disbursement (production — from bank onboarding)
# ICICI_GATEWAY_BASE_URL=https://your-icici-corp-gateway.example/pay
# ICICI_MERCHANT_ID=your_merchant_id

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here
